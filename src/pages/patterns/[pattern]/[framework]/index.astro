---
/**
 * Dynamic pattern page (English)
 *
 * This single template generates pages for all pattern/framework combinations
 * that have a meta.ts file. Patterns without meta.ts still use their static pages.
 *
 * Data flow:
 *   meta.ts        → tocItems, title, description, usageCode, apiProps, resources
 *   DemoSection    → framework-specific interactive demo
 *   TestingDocs    → testing documentation (from accessibility-data.ts)
 *   MDX content    → accessibility documentation prose
 */
import PatternLayout from '@/layouts/PatternLayout.astro';
import CodeBlock from '@/components/ui/CodeBlock.astro';
import ExternalLink from '@/components/ui/ExternalLink.astro';
import AiGuideActions from '@/components/ui/AiGuideActions.astro';
import AiGuideResourceItem from '@/components/ui/AiGuideResourceItem.astro';
import { getAccessibilityContent } from '@/lib/content-helpers';
import Prose from '@/components/ui/Prose.astro';
import FrameworkTabs from '@/components/ui/FrameworkTabs.astro';
import { ResponsiveTable } from '@/components/ui/table';
import Heading from '@/components/ui/Heading.astro';
import { FRAMEWORKS, FRAMEWORK_INFO, isValidFramework } from '@/lib/frameworks';
import { getPatterns } from '@/lib/patterns';
import type { PatternMeta } from '@/lib/pattern-meta-types';

// Glob imports for dynamic content loading
const demoReactModules = import.meta.glob<{ default: any }>(
  '/src/patterns/*/DemoSection.react.astro'
);
const demoVueModules = import.meta.glob<{ default: any }>('/src/patterns/*/DemoSection.vue.astro');
const demoSvelteModules = import.meta.glob<{ default: any }>(
  '/src/patterns/*/DemoSection.svelte.astro'
);
const demoWebComponentModules = import.meta.glob<{ default: any }>(
  '/src/patterns/*/DemoSection.web-component.astro'
);
const frameworkDemoModules = {
  react: demoReactModules,
  vue: demoVueModules,
  svelte: demoSvelteModules,
  astro: demoWebComponentModules,
} as const;
const frameworkDemoKey = {
  react: 'react',
  vue: 'vue',
  svelte: 'svelte',
  astro: 'web-component',
} as const;
const testingModules = import.meta.glob<{ default: any }>('/src/patterns/*/TestingDocs.astro');
const nativeHtmlModules = import.meta.glob<{ default: any }>(
  '/src/patterns/*/NativeHtmlNotice.astro'
);
const comparisonModules = import.meta.glob<{ default: any }>(
  '/src/patterns/*/ComparisonSection.astro'
);
const sourceModules = import.meta.glob<string>('/src/patterns/**/*.{tsx,vue,svelte,astro}', {
  query: '?raw',
  import: 'default',
});
const testModules = import.meta.glob<string>(
  '/src/patterns/**/*.test.{tsx,ts,vue.ts,svelte.ts,astro.ts}',
  {
    query: '?raw',
    import: 'default',
  }
);

export function getStaticPaths() {
  const metaModules = import.meta.glob<{ default: PatternMeta }>('/src/patterns/*/meta.ts', {
    eager: true,
  });
  const patterns = getPatterns();
  return patterns
    .filter((p) => `/src/patterns/${p.id}/meta.ts` in metaModules)
    .flatMap((p) =>
      FRAMEWORKS.map((f) => ({
        params: { pattern: p.id, framework: f },
        props: { meta: metaModules[`/src/patterns/${p.id}/meta.ts`].default },
      }))
    );
}

const { pattern, framework } = Astro.params;
const { meta } = Astro.props as { meta: PatternMeta };
if (!pattern || !framework || !isValidFramework(framework)) {
  return Astro.redirect('/patterns/');
}

const locale = 'en';

const fwMeta = meta.frameworks[framework];
if (!fwMeta) {
  throw new Error(
    `Framework "${framework}" not found in meta.ts for pattern "${pattern}". ` +
      `Available frameworks: ${Object.keys(meta.frameworks).join(', ')}`
  );
}
const fwInfo = FRAMEWORK_INFO[framework];

// Load dynamic components
const demoLoaderPath = `/src/patterns/${pattern}/DemoSection.${frameworkDemoKey[framework]}.astro`;
const demoLoader = frameworkDemoModules[framework][demoLoaderPath];
if (!demoLoader) {
  throw new Error(`DemoSection not found: ${demoLoaderPath}`);
}
const DemoSection = (await demoLoader()).default as any;
const TestingDocs = (await testingModules[`/src/patterns/${pattern}/TestingDocs.astro`]?.())
  ?.default as any;
const NativeHtmlNotice = meta.hasNativeHtmlNotice
  ? ((await nativeHtmlModules[`/src/patterns/${pattern}/NativeHtmlNotice.astro`]?.())
      ?.default as any)
  : null;
const ComparisonSection = meta.hasComparisonSection
  ? ((await comparisonModules[`/src/patterns/${pattern}/ComparisonSection.astro`]?.())
      ?.default as any)
  : null;

// Load source and test code (fail-fast to catch meta.ts typos)
const sourcePath = `/src/patterns/${pattern}/${fwMeta.sourceFile}`;
const sourceLoader = sourceModules[sourcePath];
if (!sourceLoader) {
  throw new Error(`Source file not found: ${sourcePath} (check meta.ts sourceFile)`);
}
const sourceCode = await sourceLoader();

let testCode: string | null = null;
if (fwMeta.testFile) {
  const testPath = `/src/patterns/${pattern}/${fwMeta.testFile}`;
  const testLoader = testModules[testPath];
  if (!testLoader) {
    throw new Error(`Test file not found: ${testPath} (check meta.ts testFile)`);
  }
  testCode = await testLoader();
}

// Load accessibility MDX content
const { Content: AccessibilityContent } = await getAccessibilityContent(pattern, locale);
---

<PatternLayout
  title={`${meta.title[locale]} - ${fwInfo.label}`}
  pattern={pattern}
  framework={framework}
  tocItems={meta.tocItems[locale]}
>
  <header class="mb-8">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-4">
      <h1 class="text-3xl font-bold">{meta.title[locale]}</h1>
      <AiGuideActions pattern={pattern} />
    </div>
    <p class="text-muted-foreground text-lg">
      {meta.description[locale]}
    </p>
  </header>

  <!-- Framework Selector -->
  <FrameworkTabs pattern={pattern} currentFramework={framework} />

  <!-- Demo Section -->
  <section class="mb-12">
    <Heading level={2} class="mb-4 text-xl font-semibold">Demo</Heading>
    <DemoSection locale={locale} />
    <p class="text-muted-foreground mt-2 text-sm">
      <a href="./demo/" class="text-primary hover:underline">Open demo only →</a>
    </p>
  </section>

  <!-- Native HTML Section (conditional) -->
  {
    NativeHtmlNotice && (
      <section class="mb-12">
        <Heading level={2} class="mb-4 text-xl font-semibold">
          Native HTML
        </Heading>
        <NativeHtmlNotice />
      </section>
    )
  }

  <!-- Comparison Section (conditional) -->
  {
    ComparisonSection && (
      <section class="mb-12">
        <ComparisonSection />
      </section>
    )
  }

  <!-- Accessibility Section -->
  <section class="mb-12">
    <Heading level={2} class="mb-4 text-xl font-semibold">Accessibility Features</Heading>
    <Prose>
      <AccessibilityContent />
    </Prose>
  </section>

  <!-- Source Code Section -->
  <section class="mb-12">
    <Heading level={2} class="mb-4 text-xl font-semibold">Source Code</Heading>
    <CodeBlock
      collapsible
      collapsedLines={5}
      code={sourceCode}
      lang={fwMeta.lang}
      title={fwMeta.sourceFile}
    />
  </section>

  <!-- Usage Section -->
  <section class="mb-12">
    <Heading level={2} class="mb-4 text-xl font-semibold">Usage</Heading>
    <CodeBlock
      collapsible
      collapsedLines={5}
      code={fwMeta.usageCode}
      lang={fwMeta.lang}
      title="Example"
    />
  </section>

  <!-- API Section -->
  <section class="mb-12 text-sm">
    <Heading level={2} class="mb-4 text-xl font-semibold">API</Heading>
    <ResponsiveTable>
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-border border-b">
            <th class="py-2 pr-4 text-left">Prop</th>
            <th class="py-2 pr-4 text-left">Type</th>
            <th class="py-2 pr-4 text-left">Default</th>
            <th class="py-2 text-left">Description</th>
          </tr>
        </thead>
        <tbody>
          {
            fwMeta.apiProps.map((prop) => (
              <tr class="border-border border-b">
                <td class="py-2 pr-4">
                  <code>{prop.name}</code>
                </td>
                <td class="text-muted-foreground py-2 pr-4">{prop.type}</td>
                <td class="text-muted-foreground py-2 pr-4">{prop.default}</td>
                <td class="py-2">{prop.description[locale]}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </ResponsiveTable>

    {
      fwMeta.apiSlots && fwMeta.apiSlots.length > 0 && (
        <>
          <h3 class="mt-6 mb-2 font-medium">Slots</h3>
          <ResponsiveTable>
            <table class="w-full border-collapse">
              <thead>
                <tr class="border-border border-b">
                  <th class="py-2 pr-4 text-left">Slot</th>
                  <th class="py-2 pr-4 text-left">Default</th>
                  <th class="py-2 text-left">Description</th>
                </tr>
              </thead>
              <tbody>
                {fwMeta.apiSlots.map((slot) => (
                  <tr class="border-border border-b">
                    <td class="py-2 pr-4">
                      <code>{slot.name}</code>
                    </td>
                    <td class="text-muted-foreground py-2 pr-4">{slot.default}</td>
                    <td class="py-2">{slot.description[locale]}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </ResponsiveTable>
        </>
      )
    }

    {
      fwMeta.apiSubComponents &&
        fwMeta.apiSubComponents.map((sub) => (
          <>
            <h3 class="mt-6 mb-3 text-lg font-medium">{sub.name} Props</h3>
            <ResponsiveTable>
              <table class="w-full border-collapse">
                <thead>
                  <tr class="border-border border-b">
                    <th class="py-2 pr-4 text-left">Prop</th>
                    <th class="py-2 pr-4 text-left">Type</th>
                    <th class="py-2 pr-4 text-left">Default</th>
                    <th class="py-2 text-left">Description</th>
                  </tr>
                </thead>
                <tbody>
                  {sub.props.map((prop) => (
                    <tr class="border-border border-b">
                      <td class="py-2 pr-4">
                        <code>{prop.name}</code>
                      </td>
                      <td class="text-muted-foreground py-2 pr-4">{prop.type}</td>
                      <td class="text-muted-foreground py-2 pr-4">{prop.default}</td>
                      <td class="py-2">{prop.description[locale]}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </ResponsiveTable>
          </>
        ))
    }

    {
      fwMeta.apiNote && (
        <div class="text-muted-foreground mt-4 text-sm">
          <Fragment set:html={fwMeta.apiNote[locale]} />
        </div>
      )
    }

    {
      fwMeta.apiEvents && fwMeta.apiEvents.length > 0 && (
        <>
          <h3 class="mt-6 mb-2 font-medium">Custom Events</h3>
          <ResponsiveTable>
            <table class="w-full border-collapse">
              <thead>
                <tr class="border-border border-b">
                  <th class="py-2 pr-4 text-left">Event</th>
                  <th class="py-2 pr-4 text-left">Detail</th>
                  <th class="py-2 text-left">Description</th>
                </tr>
              </thead>
              <tbody>
                {fwMeta.apiEvents.map((event) => (
                  <tr class="border-border border-b">
                    <td class="py-2 pr-4">
                      <code>{event.name}</code>
                    </td>
                    <td class="text-muted-foreground py-2 pr-4">{event.detail}</td>
                    <td class="py-2">{event.description[locale]}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </ResponsiveTable>
        </>
      )
    }
  </section>

  <!-- Testing Section -->
  <section class="mb-12">
    <Heading level={2} class="mb-4 text-xl font-semibold">Testing</Heading>
    {TestingDocs && <TestingDocs />}
    {
      testCode && fwMeta.testFile && (
        <div class="mt-6">
          <CodeBlock
            collapsible
            collapsedLines={5}
            code={testCode}
            lang={fwMeta.lang === 'tsx' ? 'tsx' : 'typescript'}
            title={fwMeta.testFile}
          />
        </div>
      )
    }
  </section>

  <!-- Resources -->
  <section>
    <Heading level={2} class="mb-4 text-xl font-semibold">Resources</Heading>
    <ul class="list-disc space-y-2 pl-6">
      {
        meta.resources.map((resource) => (
          <li>
            <ExternalLink href={resource.href} class="text-primary hover:underline">
              {resource.label[locale]}
            </ExternalLink>
          </li>
        ))
      }
      <AiGuideResourceItem pattern={pattern} />
    </ul>
  </section>
</PatternLayout>
