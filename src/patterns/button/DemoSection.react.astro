---
import { Button as ButtonReact } from './Button';

interface Props {
}
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-wrap gap-4">
    <ButtonReact client:load onClick={() => alert('Clicked!')}>Click me</ButtonReact>
