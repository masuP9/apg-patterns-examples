---
/**
 * Carousel Demo Section
 *
 * Renders carousel demos for each framework variant.
 * Includes both manual navigation and auto-rotation demos.
 */
import type { Framework } from '@/lib/frameworks';
import { CarouselDemo as CarouselDemoReact } from './CarouselDemo';
import CarouselDemoVue from './CarouselDemo.vue';
import CarouselDemoSvelte from './CarouselDemo.svelte';
import CarouselDemoAstro from './CarouselDemo.astro';

interface Props {
  framework: Framework;
}

const { framework } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<!-- Manual Navigation -->
<div class="mb-8">
  <h3 class="mb-3 text-lg font-medium">Manual Navigation</h3>
  <p class="text-muted-foreground mb-4 text-sm">
    Navigate using the tab indicators, previous/next buttons, or keyboard arrows.
  </p>
  <div class="border-border bg-background rounded-lg border p-6">
    {framework === 'react' && <CarouselDemoReact client:load basePath={basePath} />}
    {framework === 'vue' && <CarouselDemoVue client:load basePath={basePath} />}
    {framework === 'svelte' && <CarouselDemoSvelte client:load basePath={basePath} />}
    {framework === 'astro' && <CarouselDemoAstro />}
  </div>
</div>

<!-- Auto-Rotation -->
<div>
  <h3 class="mb-3 text-lg font-medium">Auto-Rotation</h3>
  <p class="text-muted-foreground mb-4 text-sm">
    Automatically rotates through slides. Pauses on hover, focus, or when the user clicks the pause
    button. Respects prefers-reduced-motion.
  </p>
  <div class="border-border bg-background rounded-lg border p-6">
    {
      framework === 'react' && (
        <CarouselDemoReact client:load variant="auto-rotate" basePath={basePath} />
      )
    }
    {
      framework === 'vue' && (
        <CarouselDemoVue client:load variant="auto-rotate" basePath={basePath} />
      )
    }
    {
      framework === 'svelte' && (
        <CarouselDemoSvelte client:load variant="auto-rotate" basePath={basePath} />
      )
    }
    {framework === 'astro' && <CarouselDemoAstro variant="auto-rotate" />}
  </div>
</div>
