---
import LinkAstro from './Link.astro';

interface Props {}
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-col items-start gap-4">
    <LinkAstro href="https://www.w3.org/WAI/ARIA/apg/">WAI-ARIA APG Documentation</LinkAstro>
    <LinkAstro href="https://example.com" target="_blank">
      External Link (opens in new tab)
    </LinkAstro>
    <LinkAstro href="#" disabled>Disabled Link</LinkAstro>
  </div>
</div>
