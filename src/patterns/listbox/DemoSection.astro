---
/**
 * Listbox Demo Section
 *
 * Renders the listbox demo for each framework variant.
 * React uses wrapper demo components with built-in data.
 * Vue/Svelte use the ListboxDemo component with props.
 * Astro uses the Listbox component directly.
 */
import type { Framework } from '@/lib/frameworks';
import {
  SingleSelectListboxDemo,
  MultiSelectListboxDemo,
  HorizontalListboxDemo,
} from './ListboxDemo';
import ListboxDemoVue from './ListboxDemo.vue';
import ListboxDemoSvelte from './ListboxDemo.svelte';
import Listbox from './Listbox.astro';

interface Props {
  framework: Framework;
}

const { framework } = Astro.props;

const fruitOptions = [
  { id: 'apple', label: 'Apple' },
  { id: 'banana', label: 'Banana' },
  { id: 'cherry', label: 'Cherry' },
  { id: 'date', label: 'Date' },
  { id: 'elderberry', label: 'Elderberry' },
  { id: 'fig', label: 'Fig' },
  { id: 'grape', label: 'Grape' },
];

const colorOptions = [
  { id: 'red', label: 'Red' },
  { id: 'orange', label: 'Orange' },
  { id: 'yellow', label: 'Yellow' },
  { id: 'green', label: 'Green', disabled: true },
  { id: 'blue', label: 'Blue' },
  { id: 'indigo', label: 'Indigo' },
  { id: 'purple', label: 'Purple' },
];
---

{
  framework === 'react' && (
    <>
      {/* Single-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Single-Select (Default)</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Selection follows focus. Use arrow keys to navigate and select.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <SingleSelectListboxDemo client:load />
        </div>
      </div>

      {/* Multi-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Multi-Select</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Focus and selection are independent. Use Space to toggle, Shift+Arrow to extend selection.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <MultiSelectListboxDemo client:load />
        </div>
      </div>

      {/* Horizontal Orientation */}
      <div>
        <h3 class="mb-3 text-lg font-medium">Horizontal Orientation</h3>
        <p class="text-muted-foreground mb-4 text-sm">Use Left/Right arrow keys for navigation.</p>
        <div class="border-border bg-background rounded-lg border p-6">
          <HorizontalListboxDemo client:load />
        </div>
      </div>
    </>
  )
}

{
  framework === 'vue' && (
    <>
      {/* Single-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Single-Select (Default)</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Selection follows focus. Use arrow keys to navigate and select.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <ListboxDemoVue
            client:load
            options={fruitOptions}
            label="Choose a fruit:"
            defaultSelectedIds={['apple']}
          />
        </div>
      </div>

      {/* Multi-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Multi-Select</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Focus and selection are independent. Use Space to toggle, Shift+Arrow to extend selection.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <ListboxDemoVue
            client:load
            options={colorOptions}
            label="Choose colors (multiple):"
            multiselectable
          />
        </div>
      </div>

      {/* Horizontal Orientation */}
      <div>
        <h3 class="mb-3 text-lg font-medium">Horizontal Orientation</h3>
        <p class="text-muted-foreground mb-4 text-sm">Use Left/Right arrow keys for navigation.</p>
        <div class="border-border bg-background rounded-lg border p-6">
          <ListboxDemoVue
            client:load
            options={fruitOptions.slice(0, 5)}
            label="Choose a fruit (horizontal):"
            orientation="horizontal"
            defaultSelectedIds={['apple']}
          />
        </div>
      </div>
    </>
  )
}

{
  framework === 'svelte' && (
    <>
      {/* Single-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Single-Select (Default)</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Selection follows focus. Use arrow keys to navigate and select.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <ListboxDemoSvelte
            client:load
            options={fruitOptions}
            label="Choose a fruit:"
            defaultSelectedIds={['apple']}
          />
        </div>
      </div>

      {/* Multi-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Multi-Select</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Focus and selection are independent. Use Space to toggle, Shift+Arrow to extend selection.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <ListboxDemoSvelte
            client:load
            options={colorOptions}
            label="Choose colors (multiple):"
            multiselectable
          />
        </div>
      </div>

      {/* Horizontal Orientation */}
      <div>
        <h3 class="mb-3 text-lg font-medium">Horizontal Orientation</h3>
        <p class="text-muted-foreground mb-4 text-sm">Use Left/Right arrow keys for navigation.</p>
        <div class="border-border bg-background rounded-lg border p-6">
          <ListboxDemoSvelte
            client:load
            options={fruitOptions.slice(0, 5)}
            label="Choose a fruit (horizontal):"
            orientation="horizontal"
            defaultSelectedIds={['apple']}
          />
        </div>
      </div>
    </>
  )
}

{
  framework === 'astro' && (
    <>
      {/* Single-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Single-Select (Default)</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Selection follows focus. Use arrow keys to navigate and select.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <label id="fruit-label-astro" class="mb-2 block text-sm font-medium">
            Choose a fruit:
          </label>
          <Listbox
            options={fruitOptions}
            defaultSelectedIds={['apple']}
            aria-labelledby="fruit-label-astro"
          />
        </div>
      </div>

      {/* Multi-Select */}
      <div class="mb-8">
        <h3 class="mb-3 text-lg font-medium">Multi-Select</h3>
        <p class="text-muted-foreground mb-4 text-sm">
          Focus and selection are independent. Use Space to toggle, Shift+Arrow to extend selection.
        </p>
        <div class="border-border bg-background rounded-lg border p-6">
          <label id="color-label-astro" class="mb-2 block text-sm font-medium">
            Choose colors (multiple):
          </label>
          <Listbox options={colorOptions} multiselectable aria-labelledby="color-label-astro" />
          <p class="text-muted-foreground mt-2 text-xs">
            Tip: Use Space to toggle, Shift+Arrow to extend selection, Ctrl+A to select all
          </p>
        </div>
      </div>

      {/* Horizontal Orientation */}
      <div>
        <h3 class="mb-3 text-lg font-medium">Horizontal Orientation</h3>
        <p class="text-muted-foreground mb-4 text-sm">Use Left/Right arrow keys for navigation.</p>
        <div class="border-border bg-background rounded-lg border p-6">
          <label id="horizontal-label-astro" class="mb-2 block text-sm font-medium">
            Choose a fruit (horizontal):
          </label>
          <Listbox
            options={fruitOptions.slice(0, 5)}
            orientation="horizontal"
            defaultSelectedIds={['apple']}
            aria-labelledby="horizontal-label-astro"
          />
        </div>
      </div>
    </>
  )
}
