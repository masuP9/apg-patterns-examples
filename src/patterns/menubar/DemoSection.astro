---
/**
 * Menubar Demo Section
 *
 * Renders the menubar demo for each framework variant.
 * React/Vue/Svelte use their respective MenubarDemo components.
 * Astro uses the Menubar component directly with inline data.
 */
import type { Framework } from '@/lib/frameworks';
import { BasicMenubarDemo } from './MenubarDemo';
import MenubarDemoVue from './MenubarDemo.vue';
import MenubarDemoSvelte from './MenubarDemo.svelte';
import Menubar, { type MenubarItem } from './Menubar.astro';
import '@patterns/menubar/menubar.css';

interface Props {
  framework: Framework;
}

const { framework } = Astro.props;

const menubarItems: MenubarItem[] = [
  {
    id: 'file',
    label: 'File',
    items: [
      { type: 'item', id: 'new', label: 'New' },
      { type: 'item', id: 'open', label: 'Open' },
      {
        type: 'submenu',
        id: 'open-recent',
        label: 'Open Recent',
        items: [
          { type: 'item', id: 'project1', label: 'project-alpha.js' },
          { type: 'item', id: 'project2', label: 'dashboard.tsx' },
          { type: 'item', id: 'project3', label: 'styles.css' },
        ],
      },
      { type: 'separator', id: 'sep1' },
      { type: 'item', id: 'save', label: 'Save' },
      { type: 'item', id: 'save-as', label: 'Save As...' },
      { type: 'separator', id: 'sep2' },
      { type: 'item', id: 'export', label: 'Export', disabled: true },
      { type: 'item', id: 'print', label: 'Print...' },
    ],
  },
  {
    id: 'edit',
    label: 'Edit',
    items: [
      { type: 'item', id: 'undo', label: 'Undo' },
      { type: 'item', id: 'redo', label: 'Redo' },
      { type: 'separator', id: 'sep3' },
      { type: 'item', id: 'cut', label: 'Cut' },
      { type: 'item', id: 'copy', label: 'Copy' },
      { type: 'item', id: 'paste', label: 'Paste' },
    ],
  },
  {
    id: 'view',
    label: 'View',
    items: [
      { type: 'checkbox', id: 'show-toolbar', label: 'Show Toolbar', checked: true },
      { type: 'checkbox', id: 'show-sidebar', label: 'Show Sidebar', checked: false },
      { type: 'separator', id: 'sep4' },
      {
        type: 'radiogroup',
        id: 'theme-group',
        label: 'Theme',
        items: [
          { type: 'radio', id: 'theme-light', label: 'Light', checked: true },
          { type: 'radio', id: 'theme-dark', label: 'Dark', checked: false },
          { type: 'radio', id: 'theme-auto', label: 'System', checked: false },
        ],
      },
    ],
  },
  {
    id: 'help',
    label: 'Help',
    items: [
      { type: 'item', id: 'docs', label: 'Documentation' },
      { type: 'item', id: 'shortcuts', label: 'Keyboard Shortcuts' },
      { type: 'separator', id: 'sep5' },
      { type: 'item', id: 'about', label: 'About' },
    ],
  },
];
---

<div class="border-border bg-background rounded-lg border p-6">
  {framework === 'react' && <BasicMenubarDemo client:load />}
  {framework === 'vue' && <MenubarDemoVue client:load />}
  {framework === 'svelte' && <MenubarDemoSvelte client:load />}
  {framework === 'astro' && <Menubar items={menubarItems} aria-label="Application" />}
</div>
