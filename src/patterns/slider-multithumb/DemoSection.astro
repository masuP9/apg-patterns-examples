---
/**
 * Multi-Thumb Slider Demo Section
 *
 * Renders the multi-thumb slider demo for each framework variant.
 * Each framework's component is statically imported to support
 * Astro's client:load directive for hydration.
 */
import type { Framework } from '@/lib/frameworks';
import { MultiThumbSlider as MultiThumbSliderReact } from './MultiThumbSlider';
import MultiThumbSliderVue from './MultiThumbSlider.vue';
import MultiThumbSliderSvelte from './MultiThumbSlider.svelte';
import MultiThumbSliderAstro from './MultiThumbSlider.astro';

interface Props {
  framework: Framework;
}

const { framework } = Astro.props;
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-col gap-8">
    {
      framework === 'react' && (
        <>
          <div>
            <MultiThumbSliderReact
              client:load
              defaultValue={[20, 80]}
              label="Price Range"
              format={'${value}'}
              aria-label={['Minimum Price', 'Maximum Price']}
            />
          </div>
          <div>
            <MultiThumbSliderReact
              client:load
              defaultValue={[25, 75]}
              label="Temperature Range"
              format={'{value}\u00B0C'}
              aria-label={['Minimum Temperature', 'Maximum Temperature']}
            />
          </div>
          <div>
            <MultiThumbSliderReact
              client:load
              defaultValue={[30, 70]}
              min={0}
              max={100}
              step={5}
              minDistance={10}
              label="Budget Range (with minDistance)"
              format={'${value}'}
              aria-label={['Minimum Budget', 'Maximum Budget']}
            />
          </div>
          <div>
            <MultiThumbSliderReact
              client:load
              defaultValue={[40, 60]}
              label="Disabled"
              disabled
              format={'{value}%'}
              aria-label={['Lower Value', 'Upper Value']}
            />
          </div>
        </>
      )
    }
    {
      framework === 'vue' && (
        <>
          <div>
            <MultiThumbSliderVue
              client:load
              defaultValue={[20, 80]}
              label="Price Range"
              format={'${value}'}
              ariaLabel={['Minimum Price', 'Maximum Price']}
            />
          </div>
          <div>
            <MultiThumbSliderVue
              client:load
              defaultValue={[25, 75]}
              label="Temperature Range"
              format={'{value}\u00B0C'}
              ariaLabel={['Minimum Temperature', 'Maximum Temperature']}
            />
          </div>
          <div>
            <MultiThumbSliderVue
              client:load
              defaultValue={[30, 70]}
              min={0}
              max={100}
              step={5}
              minDistance={10}
              label="Budget Range (with minDistance)"
              format={'${value}'}
              ariaLabel={['Minimum Budget', 'Maximum Budget']}
            />
          </div>
          <div>
            <MultiThumbSliderVue
              client:load
              defaultValue={[40, 60]}
              label="Disabled"
              disabled
              format={'{value}%'}
              ariaLabel={['Lower Value', 'Upper Value']}
            />
          </div>
        </>
      )
    }
    {
      framework === 'svelte' && (
        <>
          <div>
            <MultiThumbSliderSvelte
              client:load
              defaultValue={[20, 80]}
              label="Price Range"
              format={'${value}'}
              ariaLabel={['Minimum Price', 'Maximum Price']}
            />
          </div>
          <div>
            <MultiThumbSliderSvelte
              client:load
              defaultValue={[25, 75]}
              label="Temperature Range"
              format={'{value}\u00B0C'}
              ariaLabel={['Minimum Temperature', 'Maximum Temperature']}
            />
          </div>
          <div>
            <MultiThumbSliderSvelte
              client:load
              defaultValue={[30, 70]}
              min={0}
              max={100}
              step={5}
              minDistance={10}
              label="Budget Range (with minDistance)"
              format={'${value}'}
              ariaLabel={['Minimum Budget', 'Maximum Budget']}
            />
          </div>
          <div>
            <MultiThumbSliderSvelte
              client:load
              defaultValue={[40, 60]}
              label="Disabled"
              disabled
              format={'{value}%'}
              ariaLabel={['Lower Value', 'Upper Value']}
            />
          </div>
        </>
      )
    }
    {
      framework === 'astro' && (
        <>
          <div>
            <MultiThumbSliderAstro
              defaultValue={[20, 80]}
              label="Price Range"
              format={'${value}'}
              aria-label-lower="Minimum Price"
              aria-label-upper="Maximum Price"
            />
          </div>
          <div>
            <MultiThumbSliderAstro
              defaultValue={[25, 75]}
              label="Temperature Range"
              format={'{value}\u00B0C'}
              aria-label-lower="Minimum Temperature"
              aria-label-upper="Maximum Temperature"
            />
          </div>
          <div>
            <MultiThumbSliderAstro
              defaultValue={[30, 70]}
              min={0}
              max={100}
              step={5}
              minDistance={10}
              label="Budget Range (with minDistance)"
              format={'${value}'}
              aria-label-lower="Minimum Budget"
              aria-label-upper="Maximum Budget"
            />
          </div>
          <div>
            <MultiThumbSliderAstro
              defaultValue={[40, 60]}
              label="Disabled"
              disabled
              format={'{value}%'}
              aria-label-lower="Lower Value"
              aria-label-upper="Upper Value"
            />
          </div>
        </>
      )
    }
  </div>
</div>
