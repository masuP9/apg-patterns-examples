---
/**
 * Slider Demo Section
 *
 * Renders the slider demo for each framework variant.
 * Each framework's component is statically imported to support
 * Astro's client:load directive for hydration.
 */
import type { Framework } from '@/lib/frameworks';
import { Slider as SliderReact } from './Slider';
import SliderVue from './Slider.vue';
import SliderSvelte from './Slider.svelte';
import SliderAstro from './Slider.astro';

interface Props {
  framework: Framework;
}

const { framework } = Astro.props;
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-col gap-6">
    {
      framework === 'react' && (
        <>
          <div>
            <SliderReact client:load defaultValue={50} label="Volume" format="{value}%" />
          </div>
          <div>
            <SliderReact client:load defaultValue={75} label="Progress" format="{value}%" />
          </div>
          <div>
            <SliderReact
              client:load
              defaultValue={3}
              min={1}
              max={5}
              step={1}
              label="Rating"
              format="{value} of {max}"
            />
          </div>
          <div>
            <SliderReact
              client:load
              defaultValue={50}
              label="Vertical"
              orientation="vertical"
              format="{value}%"
            />
          </div>
          <div>
            <SliderReact
              client:load
              defaultValue={50}
              label="Disabled"
              disabled
              format="{value}%"
            />
          </div>
        </>
      )
    }
    {
      framework === 'vue' && (
        <>
          <div>
            <SliderVue client:load defaultValue={50} label="Volume" format="{value}%" />
          </div>
          <div>
            <SliderVue client:load defaultValue={75} label="Progress" format="{value}%" />
          </div>
          <div>
            <SliderVue
              client:load
              defaultValue={3}
              min={1}
              max={5}
              step={1}
              label="Rating"
              format="{value} of {max}"
            />
          </div>
          <div>
            <SliderVue
              client:load
              defaultValue={50}
              label="Vertical"
              orientation="vertical"
              format="{value}%"
            />
          </div>
          <div>
            <SliderVue client:load defaultValue={50} label="Disabled" disabled format="{value}%" />
          </div>
        </>
      )
    }
    {
      framework === 'svelte' && (
        <>
          <div>
            <SliderSvelte client:load defaultValue={50} label="Volume" format="{value}%" />
          </div>
          <div>
            <SliderSvelte client:load defaultValue={75} label="Progress" format="{value}%" />
          </div>
          <div>
            <SliderSvelte
              client:load
              defaultValue={3}
              min={1}
              max={5}
              step={1}
              label="Rating"
              format="{value} of {max}"
            />
          </div>
          <div>
            <SliderSvelte
              client:load
              defaultValue={50}
              label="Vertical"
              orientation="vertical"
              format="{value}%"
            />
          </div>
          <div>
            <SliderSvelte
              client:load
              defaultValue={50}
              label="Disabled"
              disabled
              format="{value}%"
            />
          </div>
        </>
      )
    }
    {
      framework === 'astro' && (
        <>
          <div>
            <SliderAstro defaultValue={50} label="Volume" format="{value}%" />
          </div>
          <div>
            <SliderAstro defaultValue={75} label="Progress" format="{value}%" />
          </div>
          <div>
            <SliderAstro
              defaultValue={3}
              min={1}
              max={5}
              step={1}
              label="Rating"
              format="{value} of {max}"
            />
          </div>
          <div>
            <SliderAstro
              defaultValue={50}
              label="Vertical"
              orientation="vertical"
              format="{value}%"
            />
          </div>
          <div>
            <SliderAstro defaultValue={50} label="Disabled" disabled format="{value}%" />
          </div>
        </>
      )
    }
  </div>
</div>
