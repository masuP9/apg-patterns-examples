---
import SpinbuttonAstro from './Spinbutton.astro';

interface Props {}
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-col gap-6">
    <div><SpinbuttonAstro defaultValue={5} min={0} max={100} label="Quantity" /></div>
    <div>
      <SpinbuttonAstro defaultValue={3} min={1} max={10} label="Rating" format="{value} of {max}" />
    </div>
    <div><SpinbuttonAstro defaultValue={0.5} min={0} max={1} step={0.1} label="Opacity" /></div>
    <div><SpinbuttonAstro defaultValue={0} label="Unbounded" showButtons={true} /></div>
    <div>
      <SpinbuttonAstro defaultValue={50} min={0} max={100} label="Read-only" readOnly />
    </div>
    <div>
      <SpinbuttonAstro defaultValue={50} min={0} max={100} label="Disabled" disabled />
    </div>
  </div>
</div>
