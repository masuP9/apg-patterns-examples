---
import type { Framework } from '@/lib/frameworks';
import SwitchVue from './Switch.vue';

interface Props {
  framework?: Framework;
}
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-col items-start gap-4">
    <SwitchVue client:load>Wi-Fi</SwitchVue>
    <SwitchVue client:load initialChecked={true}>Bluetooth</SwitchVue>
    <SwitchVue client:load disabled>Airplane Mode (disabled)</SwitchVue>
  </div>
</div>
