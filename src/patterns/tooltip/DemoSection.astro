---
/**
 * Tooltip Demo Section
 *
 * Renders the tooltip demo for each framework variant.
 * React and Vue use inline Tooltip components with client:load.
 * Svelte uses a dedicated TooltipDemo component with client:only.
 * Astro uses static Tooltip components (Web Component handles interactivity).
 */
import type { Framework } from '@/lib/frameworks';
import { Tooltip as TooltipReact } from './Tooltip';
import TooltipVue from './Tooltip.vue';
import TooltipDemoSvelte from './TooltipDemo.svelte';
import TooltipAstro from './Tooltip.astro';

interface Props {
  framework: Framework;
}

const { framework } = Astro.props;
---

<div class="border-border bg-background rounded-lg border p-6">
  {
    framework === 'react' && (
      <div class="flex flex-wrap items-center gap-8">
        <TooltipReact content="Save your changes" client:load>
          <button class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-md px-4 py-2">
            Save
          </button>
        </TooltipReact>

        <TooltipReact content="This appears on the right" placement="right" client:load>
          <button class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2">
            Right tooltip
          </button>
        </TooltipReact>

        <TooltipReact content="This appears below" placement="bottom" client:load>
          <button class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2">
            Bottom tooltip
          </button>
        </TooltipReact>

        <TooltipReact content="This tooltip is disabled" disabled client:load>
          <button class="bg-muted text-muted-foreground rounded-md px-4 py-2">
            Disabled tooltip
          </button>
        </TooltipReact>
      </div>
    )
  }

  {
    framework === 'vue' && (
      <div class="flex flex-wrap items-center gap-8">
        <TooltipVue content="Save your changes" client:load>
          <button class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-md px-4 py-2">
            Save
          </button>
        </TooltipVue>

        <TooltipVue content="This appears on the right" placement="right" client:load>
          <button class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2">
            Right tooltip
          </button>
        </TooltipVue>

        <TooltipVue content="This appears below" placement="bottom" client:load>
          <button class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2">
            Bottom tooltip
          </button>
        </TooltipVue>

        <TooltipVue content="This tooltip is disabled" disabled={true} client:load>
          <button class="bg-muted text-muted-foreground rounded-md px-4 py-2">
            Disabled tooltip
          </button>
        </TooltipVue>
      </div>
    )
  }

  {framework === 'svelte' && <TooltipDemoSvelte client:only="svelte" />}

  {
    framework === 'astro' && (
      <div class="flex flex-wrap items-center gap-8">
        <TooltipAstro content="Save your changes">
          <button class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-md px-4 py-2">
            Save
          </button>
        </TooltipAstro>

        <TooltipAstro content="This appears on the right" placement="right">
          <button class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2">
            Right tooltip
          </button>
        </TooltipAstro>

        <TooltipAstro content="This appears below" placement="bottom">
          <button class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2">
            Bottom tooltip
          </button>
        </TooltipAstro>

        <TooltipAstro content="This tooltip is disabled" disabled>
          <button class="bg-muted text-muted-foreground rounded-md px-4 py-2">
            Disabled tooltip
          </button>
        </TooltipAstro>
      </div>
    )
  }
</div>
