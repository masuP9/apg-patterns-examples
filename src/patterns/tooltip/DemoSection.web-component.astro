---
import TooltipAstro from './Tooltip.astro';

interface Props {}
---

<div class="border-border bg-background rounded-lg border p-6">
  <div class="flex flex-wrap items-center gap-8">
    <TooltipAstro content="Save your changes">
      <button class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-md px-4 py-2">
        Save
      </button>
    </TooltipAstro>

    <TooltipAstro content="This appears on the right" placement="right">
      <button
        class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2"
      >
        Right tooltip
      </button>
    </TooltipAstro>

    <TooltipAstro content="This appears below" placement="bottom">
      <button
        class="bg-secondary text-secondary-foreground hover:bg-secondary/90 rounded-md px-4 py-2"
      >
        Bottom tooltip
      </button>
    </TooltipAstro>

    <TooltipAstro content="This tooltip is disabled" disabled>
      <button class="bg-muted text-muted-foreground rounded-md px-4 py-2">Disabled tooltip</button>
    </TooltipAstro>
  </div>
</div>
