---
import type { Framework } from '@/lib/frameworks';
import type { Locale } from '@/i18n/ui';
import TreeGridAstro from './TreeGrid.astro';
import { columnsEn, columnsJa, nodesEn, nodesJa } from './treegrid-demo-data';

interface Props {
  framework?: Framework;
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const isJa = locale === 'ja';

const demoDescription = isJa
  ? 'ÁüĘŚćį„ā≠„Éľ„ĀßÁßĽŚčē„Äārowheader„ĀßArrowRight/Left„ĀßŚĪēťĖč/śäė„āä„Āü„Āü„ĀŅ„ÄāSpace„ĀßŤ°Ć„āíťĀłśäě„Äā'
  : 'Navigate with arrow keys. At rowheader, use ArrowRight/Left to expand/collapse. Press Space to select rows.';

const columns = isJa ? columnsJa : columnsEn;
const nodes = isJa ? nodesJa : nodesEn;
const ariaLabel = isJa ? '„Éē„ā°„ā§„Éę„ÉĖ„É©„ā¶„ā∂' : 'File browser';
---

<div class="border-border bg-background rounded-lg border p-6">
  <p class="text-muted-foreground mb-4 text-sm">
    {demoDescription}
  </p>
  <TreeGridAstro
    columns={columns}
    nodes={nodes}
    ariaLabel={ariaLabel}
    selectable
    multiselectable
    defaultExpandedIds={['docs']}
  />
</div>
