---
/**
 * Interactive demo for the focusgroup HTML attribute.
 *
 * Shows three demos based on the Microsoft Edge focusgroup demos:
 * 1. Basic toolbar (focusgroup="toolbar")
 * 2. Wrapping toolbar (focusgroup="toolbar wrap")
 * 3. Vertical toolbar (focusgroup="toolbar block")
 *
 * Requires a browser with native focusgroup support (Chromium 133+).
 * A browser support notice is shown dynamically via feature detection.
 *
 * @see https://microsoftedge.github.io/Demos/focusgroup/
 */
---

<div class="focusgroup-demo space-y-8">
  {/* Browser support notice — shown dynamically */}
  <div
    class="focusgroup-support-notice bg-muted/50 rounded-lg border p-4 text-sm"
    hidden
  >
    <p class="font-semibold">
      Your browser does not support the <code>focusgroup</code> attribute yet.
    </p>
    <p class="text-muted-foreground mt-1">
      The <code>focusgroup</code> attribute is currently supported in
      Chromium-based browsers (Chrome 133+, Edge 133+). The demos below show
      the intended markup, but arrow key navigation requires browser support.
    </p>
  </div>
  <div
    class="focusgroup-supported-notice rounded-lg border border-green-200 bg-green-50 p-4 text-sm dark:border-green-800 dark:bg-green-950/20"
    hidden
  >
    <p class="font-semibold text-green-800 dark:text-green-200">
      Your browser supports the <code>focusgroup</code> attribute!
    </p>
    <p class="text-muted-foreground mt-1">
      Try tabbing into each demo below and using arrow keys to navigate.
      Notice how the browser handles roving tabindex automatically — no
      JavaScript needed.
    </p>
  </div>

  {/* Demo 1: Basic toolbar */}
  <figure class="rounded-lg border p-4">
    <figcaption class="mb-3 text-sm font-semibold">
      Basic Toolbar (<code class="bg-muted rounded px-1 text-xs"
        >focusgroup="toolbar"</code
      >)
    </figcaption>
    <div
      class="flex gap-2"
      role="toolbar"
      aria-label="Text formatting (focusgroup demo)"
      focusgroup="toolbar"
    >
      <button
        type="button"
        class="rounded border px-3 py-1.5 text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Bold</button
      >
      <button
        type="button"
        class="rounded border px-3 py-1.5 text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Italic</button
      >
      <button
        type="button"
        class="rounded border px-3 py-1.5 text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Underline</button
      >
      <button
        type="button"
        class="rounded border px-3 py-1.5 text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Strikethrough</button
      >
    </div>
    <p class="text-muted-foreground mt-2 text-xs">
      Tab to enter the toolbar, then use <kbd>&#8592;</kbd> <kbd>&#8594;</kbd>
      arrow keys to navigate. Tab again to exit. Focus stops at the edges.
    </p>
  </figure>

  {/* Demo 2: Wrapping toolbar */}
  <figure class="rounded-lg border p-4">
    <figcaption class="mb-3 text-sm font-semibold">
      Wrapping Toolbar (<code class="bg-muted rounded px-1 text-xs"
        >focusgroup="toolbar wrap"</code
      >)
    </figcaption>
    <div
      class="flex gap-2"
      role="toolbar"
      aria-label="Color palette (focusgroup wrap demo)"
      focusgroup="toolbar wrap"
    >
      <button
        type="button"
        class="h-8 w-8 rounded-full border-2 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        style="background-color: #ef4444;"
        aria-label="Red"></button>
      <button
        type="button"
        class="h-8 w-8 rounded-full border-2 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        style="background-color: #f97316;"
        aria-label="Orange"></button>
      <button
        type="button"
        class="h-8 w-8 rounded-full border-2 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        style="background-color: #eab308;"
        aria-label="Yellow"></button>
      <button
        type="button"
        class="h-8 w-8 rounded-full border-2 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        style="background-color: #22c55e;"
        aria-label="Green"></button>
      <button
        type="button"
        class="h-8 w-8 rounded-full border-2 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        style="background-color: #3b82f6;"
        aria-label="Blue"></button>
    </div>
    <p class="text-muted-foreground mt-2 text-xs">
      Use <kbd>&#8592;</kbd> <kbd>&#8594;</kbd> arrow keys. Focus wraps around
      from last to first and vice versa.
    </p>
  </figure>

  {/* Demo 3: Vertical toolbar */}
  <figure class="rounded-lg border p-4">
    <figcaption class="mb-3 text-sm font-semibold">
      Vertical Toolbar (<code class="bg-muted rounded px-1 text-xs"
        >focusgroup="toolbar block"</code
      >)
    </figcaption>
    <div
      class="flex flex-col gap-1 w-fit"
      role="toolbar"
      aria-label="Document actions (focusgroup vertical demo)"
      aria-orientation="vertical"
      focusgroup="toolbar block"
    >
      <button
        type="button"
        class="rounded border px-4 py-1.5 text-left text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Cut</button
      >
      <button
        type="button"
        class="rounded border px-4 py-1.5 text-left text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Copy</button
      >
      <button
        type="button"
        class="rounded border px-4 py-1.5 text-left text-sm transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none"
        >Paste</button
      >
    </div>
    <p class="text-muted-foreground mt-2 text-xs">
      Use <kbd>&#8593;</kbd> <kbd>&#8595;</kbd> arrow keys to navigate.
      <kbd>&#8592;</kbd> <kbd>&#8594;</kbd> do nothing.
      <code>block</code> overrides <code>toolbar</code>'s default inline axis.
    </p>
  </figure>
</div>

<script>
  const supported = 'focusgroup' in HTMLElement.prototype;
  const noticeUnsupported = document.querySelector('.focusgroup-support-notice');
  const noticeSupported = document.querySelector('.focusgroup-supported-notice');

  if (supported) {
    noticeSupported?.removeAttribute('hidden');
  } else {
    noticeUnsupported?.removeAttribute('hidden');
  }
</script>
